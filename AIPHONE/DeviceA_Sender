#include <WiFi.h>
#include <WiFiUdp.h>
#include <driver/i2s.h>

// Configura tu WiFi
const char* ssid = "Electromedicina_guest";
const char* password = "Wifi-Gratis";

// IP y puerto del PC
const char* pcIP = "192.168.3.157";  // cambiar por tu PC
const uint16_t pcPort = 5005;

// Pines INMP441
#define I2S_BCLK 14
#define I2S_LRC  15
#define I2S_SD_IN 34

#define SAMPLE_RATE 8000
#define BUFFER_LEN 256

// Factor de ganancia (1.0 = normal)
#define GAIN 2.0

int32_t micBuffer[BUFFER_LEN];
int16_t txBuffer[BUFFER_LEN];

WiFiUDP udp;

void setup() {
  Serial.begin(115200);
  WiFi.begin(ssid, password);
  Serial.print("Conectando WiFi...");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("Conectado!");
  Serial.print("IP ESP32: "); Serial.println(WiFi.localIP());

  i2s_config_t i2s_config = {
    .mode = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_RX),
    .sample_rate = SAMPLE_RATE,
    .bits_per_sample = I2S_BITS_PER_SAMPLE_32BIT,
    .channel_format = I2S_CHANNEL_FMT_ONLY_LEFT,
    .communication_format = I2S_COMM_FORMAT_STAND_I2S,
    .intr_alloc_flags = ESP_INTR_FLAG_LEVEL1,
    .dma_buf_count = 8,
    .dma_buf_len = BUFFER_LEN,
    .use_apll = false
  };

  i2s_pin_config_t pin_config = {
    .bck_io_num = I2S_BCLK,
    .ws_io_num  = I2S_LRC,
    .data_out_num = I2S_PIN_NO_CHANGE,
    .data_in_num  = I2S_SD_IN
  };

  i2s_driver_install(I2S_NUM_0, &i2s_config, 0, NULL);
  i2s_set_pin(I2S_NUM_0, &pin_config);

  Serial.println("Streaming UDP iniciado");
}

void loop() {
  size_t bytesRead;
  i2s_read(I2S_NUM_0, micBuffer, sizeof(micBuffer), &bytesRead, portMAX_DELAY);
  int samples = bytesRead / 4;

  // Convertir 32-bit mic -> 16-bit PCM + ganancia
  for (int i = 0; i < samples; i++) {
    int32_t sample = micBuffer[i] >> 16;      // convertir a 16-bit
    sample = (int32_t)(sample * GAIN);        // aplicar ganancia
    // Evitar saturación
    if (sample > 32767) sample = 32767;
    if (sample < -32768) sample = -32768;
    txBuffer[i] = (int16_t)sample;
  }

  // Enviar UDP al PC
  udp.beginPacket(pcIP, pcPort);
  udp.write((uint8_t*)txBuffer, samples * 2);
  udp.endPacket();
}