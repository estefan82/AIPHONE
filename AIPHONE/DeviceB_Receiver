#include <WiFi.h>
#include <WiFiUdp.h>
#include <driver/i2s.h>

// --- Configuración WiFi ---
const char* ssid = "Electromedicina_guest";
const char* password = "Wifi-Gratis";
const uint16_t listenPort = 5005;

// --- Pines MAX98357A ---
#define I2S_BCLK 14
#define I2S_LRC  15
#define I2S_DIN  22   // SD_IN para salida I2S

// --- Factor de ganancia ---
#define GAIN 3.0  // 1.0 = sin cambio, 2.0 = doble volumen

#define SAMPLE_RATE 8000
#define BUFFER_LEN 256  // 256 muestras por paquete

WiFiUDP udp;
int16_t audioBuffer[BUFFER_LEN];

void setup() {
  Serial.begin(115200);

  // Conectar WiFi
  WiFi.begin(ssid, password);
  Serial.print("Conectando a WiFi...");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("Conectado!");
  Serial.print("IP ESP32 B: "); Serial.println(WiFi.localIP());

  // Configurar I2S (salida)
  i2s_config_t i2s_config = {
    .mode = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_TX),
    .sample_rate = SAMPLE_RATE,
    .bits_per_sample = I2S_BITS_PER_SAMPLE_16BIT,
    .channel_format = I2S_CHANNEL_FMT_ONLY_LEFT,
    .communication_format = I2S_COMM_FORMAT_I2S_MSB,
    .intr_alloc_flags = 0,
    .dma_buf_count = 8,
    .dma_buf_len = BUFFER_LEN,
    .use_apll = false
  };

  i2s_pin_config_t pin_config = {
    .bck_io_num = I2S_BCLK,
    .ws_io_num  = I2S_LRC,
    .data_out_num = I2S_DIN,
    .data_in_num  = I2S_PIN_NO_CHANGE
  };

  i2s_driver_install(I2S_NUM_0, &i2s_config, 0, NULL);
  i2s_set_pin(I2S_NUM_0, &pin_config);

  // Iniciar UDP
  udp.begin(listenPort);
  Serial.println("Esperando audio por UDP...");
}

void loop() {
  int packetSize = udp.parsePacket();
  if (packetSize > 0) {
    if (packetSize > BUFFER_LEN * 2) packetSize = BUFFER_LEN * 2;
    int len = udp.read((uint8_t*)audioBuffer, packetSize);

    // Aplicar ganancia fija
    for (int i = 0; i < len / 2; i++) {
      int32_t sample = (int32_t)(audioBuffer[i] * GAIN);
      // Clipping seguro
      if (sample > 32767) sample = 32767;
      if (sample < -32768) sample = -32768;
      audioBuffer[i] = (int16_t)sample;
    }

    // Enviar a MAX98357A
    size_t bytesWritten;
    i2s_write(I2S_NUM_0, audioBuffer, len, &bytesWritten, portMAX_DELAY);
  }
}